{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Book Brief",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "run_id", "source_prompt", "brief_status", "writing_intent", "required_user_questions", "approval_required"],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string", "minLength": 1 },
    "source_prompt": { "type": "string", "minLength": 1 },
    "brief_status": { "type": "string", "enum": ["QUESTIONS_PENDING", "USER_APPROVED", "BLOCKED"] },
    "writing_intent": { "type": "object" },
    "required_user_questions": { "type": "array", "minItems": 1 },
    "approval_required": { "type": "string", "const": "runtime/approvals/book-brief-approval.json" }
  }
}
