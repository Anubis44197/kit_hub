{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Compliance Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "phase",
    "required_agents",
    "agents_executed",
    "required_references",
    "loaded_state_files",
    "output_artifacts",
    "contract_status",
    "missing_items"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["propose", "design-big", "design-small", "create", "polish", "rewrite", "export"]
    },
    "required_agents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "agents_executed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_references": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "loaded_state_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "output_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "contract_status": {
      "type": "string",
      "enum": ["PASS", "BLOCKED"]
    },
    "missing_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
