{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Compliance Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "phase",
    "required_agents",
    "agents_executed",
    "required_references",
    "loaded_state_files",
    "output_artifacts",
    "artifact_hashes",
    "contract_hashes",
    "agent_statuses",
    "phase_authority",
    "completed_at",
    "contract_status",
    "missing_items"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["propose", "design-big", "design-small", "create", "polish", "rewrite", "export"]
    },
    "required_agents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "agents_executed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_references": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "loaded_state_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "output_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "artifact_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "contract_hashes": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "enum": [
              "runtime/agent-registry.json",
              "runtime/agent-status-contract.json",
              "runtime/phase-contracts/propose.json",
              "runtime/phase-contracts/design-big.json",
              "runtime/phase-contracts/design-small.json",
              "runtime/phase-contracts/create.json",
              "runtime/phase-contracts/polish.json",
              "runtime/phase-contracts/rewrite.json",
              "runtime/phase-contracts/export.json"
            ]
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "agent_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent", "status"],
        "properties": {
          "agent": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "blocked", "timed_out", "invalid_output"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "phase_authority": {
      "type": "string",
      "enum": ["local_adapter_scaffold", "manual_ide_agent", "provider_command", "human_operator"]
    },
    "completed_at": { "type": "string", "minLength": 1 },
    "generation_boundary": { "type": "string", "minLength": 1 },
    "creative_authority": { "type": "string", "minLength": 1 },
    "research_boundary": { "type": "string", "minLength": 1 },
    "contract_status": {
      "type": "string",
      "enum": ["PASS", "BLOCKED"]
    },
    "missing_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
